# Postgres (Docker: virya-postgres-test, host port 55432 -> 5432)
# Example: postgresql://investments_app:YOUR_PASSWORD@localhost:55432/investments
DATABASE_URL=postgresql://investments_app:password@localhost:55432/investments

# Twelve Data API key (https://twelvedata.com)
TWELVE_DATA_API_KEY=

# Server
PORT=3001

# Use mock market data instead of Twelve Data (true/false)
USE_MOCK_MARKET_DATA=false
